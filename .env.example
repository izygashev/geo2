# ===========================================
# Geo Studio Environment Variables
# Copy this file to .env and fill in your values
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/geo_saas"

# NextAuth.js (generate with: openssl rand -base64 32)
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=""

# YooKassa (https://yookassa.ru/my/shop-settings)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_TEST_MODE="true"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (email notifications, https://resend.com/api-keys)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Geo Studio <noreply@yourdomain.com>"

# -- Scraping providers (waterfall: Firecrawl > ScrapingBee > Playwright+proxy > fetch) --
# Set SCRAPING_PROVIDER to force a specific one: auto | firecrawl | scrapingbee | playwright
SCRAPING_PROVIDER=auto

# Provider 1: Firecrawl — best anti-bot (Cloudflare, Qrator, Imperva), returns clean Markdown
# https://firecrawl.dev  — free tier: 500 pages/month
FIRECRAWL_API_KEY=

# Provider 2: ScrapingBee — residential proxy pool + JS rendering
# https://scrapingbee.com  — free tier: 1000 credits
SCRAPINGBEE_API_KEY=

# Provider 3: BrightData proxy for Playwright (optional — without it Playwright runs direct)
# Format: http://username:password@brd.superproxy.io:22225
# https://brightdata.com
BRIGHTDATA_PROXY_URL=
