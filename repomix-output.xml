<file path="src/app/api/projects/[id]/competitors/route.ts">
import { NextRequest, NextResponse } from "next/server";
import { auth } from "@/lib/auth";
import { prisma } from "@/lib/prisma";
import { z } from "zod";
import { getPlanLimits } from "@/lib/plan-limits";

const CompetitorsSchema = z.object({
  competitorUrls: z
    .array(z.string().url("Некорректный URL"))
    .max(3, "Максимум 3 конкурента"),
});

export async function PATCH(
  req: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  try {
    const session = await auth();
    if (!session?.user?.id) {
      return NextResponse.json({ error: "Unauthorized" }, { status: 401 });
    }

    const { id } = await params;

    const project = await prisma.project.findUnique({
      where: { id },
      select: { userId: true },
    });

    if (!project) {
      return NextResponse.json({ error: "Проект не найден" }, { status: 404 });
    }
    if (project.userId !== session.user.id) {
      return NextResponse.json({ error: "Доступ запрещён" }, { status: 403 });
    }

    // Проверяем план
    const user = await prisma.user.findUnique({
      where: { id: session.user.id },
      select: { plan: true },
    });
    const limits = getPlanLimits(user?.plan ?? "FREE");

    if (!limits.competitorBenchmark) {
      return NextResponse.json(
        { error: "Конкурентный бенчмарк доступен на тарифах Pro и Agency" },
        { status: 403 }
      );
    }

    const body = await req.json();
    const parsed = CompetitorsSchema.safeParse(body);

    if (!parsed.success) {
      return NextResponse.json(
        { error: parsed.error.issues[0]?.message ?? "Невалидные данные" },
        { status: 400 }
      );
    }

    await prisma.project.update({
      where: { id },
      data: { competitorUrls: parsed.data.competitorUrls },
    });

    return NextResponse.json({ success: true, competitorUrls: parsed.data.competitorUrls });
  } catch {
    return NextResponse.json(
      { error: "Внутренняя ошибка сервера" },
      { status: 500 }
    );
  }
}
</file>

