@import "tailwindcss";
@import "tw-animate-css";
@import "shadcn/tailwind.css";

@plugin "@tailwindcss/typography";

@custom-variant dark (&:is(.dark *));

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-roobert), ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-mono: var(--font-geist-mono);
  --font-heading: var(--font-roobert), ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-roobert: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
  --color-sidebar-ring: var(--sidebar-ring);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar: var(--sidebar);

  /* ── Monopo London design tokens ── */
  --color-midnight-canvas: #000000;
  --color-ghost-white:     #ffffff;
  --color-subtle-gray:     #7f7f7f;
  --color-medium-gray:     #666970;
  --color-nebula-accent:   #cd5a07;
  --gradient-nebula: radial-gradient(
    circle at center,
    #cc490c, #ce510b, #cf590b, #d15f0a, #d2660a,
    #ca7619, #c38428, #bb9136, #aca753,
    #9ac171, #84dc92, #65faca
  );

  /* ── Monopo London spacing reference (prefixed to avoid overriding Tailwind scale) ── */
  --mono-spacing-5:   5px;
  --mono-spacing-14:  14px;
  --mono-spacing-15:  15px;
  --mono-spacing-17:  17px;
  --mono-spacing-25:  25px;
  --mono-spacing-35:  35px;
  --mono-spacing-55:  55px;
  --mono-spacing-56:  56px;
  --mono-spacing-111: 111px;

  /* ── Letter spacing ── */
  --tracking-editorial: 0.15em;
  --color-chart-5: var(--chart-5);
  --color-chart-4: var(--chart-4);
  --color-chart-3: var(--chart-3);
  --color-chart-2: var(--chart-2);
  --color-chart-1: var(--chart-1);
  --color-ring: var(--ring);
  --color-input: var(--input);
  --color-border: var(--border);
  --color-destructive: var(--destructive);
  --color-accent-foreground: var(--accent-foreground);
  --color-accent: var(--accent);
  --color-muted-foreground: var(--muted-foreground);
  --color-muted: var(--muted);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-secondary: var(--secondary);
  --color-primary-foreground: var(--primary-foreground);
  --color-primary: var(--primary);
  --color-popover-foreground: var(--popover-foreground);
  --color-popover: var(--popover);
  --color-card-foreground: var(--card-foreground);
  --color-card: var(--card);
  --radius-sm: calc(var(--radius) * 0.6);
  --radius-md: calc(var(--radius) * 0.8);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) * 1.4);
  --radius-2xl: calc(var(--radius) * 1.8);
  --radius-3xl: calc(var(--radius) * 2.2);
  --radius-4xl: calc(var(--radius) * 2.6);
}

/* ═══════════════════════════════════════════════════════════
   Monopo London — Midnight Canvas Design System
   Dark atmospheric base · Ghost White type · Nebula accents
   Palette mapped to shadcn/ui tokens (HSL without hsl() wrapper)
   ═══════════════════════════════════════════════════════════ */

/*
  Color Reference:
  --color-midnight-canvas : #000000  →   0   0%   0%
  --color-ghost-white     : #ffffff  →   0   0% 100%
  --color-subtle-gray     : #7f7f7f  →   0   0%  50%
  --color-medium-gray     : #666970  → 222   5%  42%
  --color-nebula-accent   : #cd5a07  →  25  93%  42%
*/

:root {
  /* ── Surfaces ── */
  --background:               0 0% 0%;       /* Midnight Canvas #000000       */
  --foreground:               0 0% 100%;     /* Ghost White    #ffffff         */

  --card:                     0 0% 4%;       /* Slightly elevated dark surface  */
  --card-foreground:          0 0% 100%;

  --popover:                  0 0% 4%;
  --popover-foreground:       0 0% 100%;

  /* ── Brand ── */
  --primary:                  0 0% 100%;     /* Ghost White — pill buttons, CTAs */
  --primary-foreground:       0 0% 0%;       /* Midnight Canvas text on white   */

  --secondary:                0 0% 10%;      /* Subtle dark card / chip surface  */
  --secondary-foreground:     0 0% 50%;      /* Subtle Gray for labels           */

  --muted:                    0 0% 7%;
  --muted-foreground:         0 0% 50%;      /* Subtle Gray #7f7f7f             */

  --accent:                   25 93% 42%;    /* Nebula accent #cd5a07           */
  --accent-foreground:        0 0% 100%;

  /* ── Semantic ── */
  --destructive:              0 72% 51%;     /* #DC2626                         */

  /* ── Chrome ── */
  --border:                   222 5% 42%;    /* Medium Gray #666970             */
  --input:                    222 5% 42%;    /* Same — outlines on dark surface  */
  --ring:                     0 0% 50%;      /* Subtle Gray                     */

  /* ── Charts (nebula gradient stops) ── */
  --chart-1:                  25 93% 42%;    /* #cd5a07 — warm orange           */
  --chart-2:                  86 40% 59%;    /* #9ac171 — sage green            */
  --chart-3:                  128 58% 69%;   /* #84dc92 — mint green            */
  --chart-4:                  162 95% 69%;   /* #65faca — seafoam               */
  --chart-5:                  222 5% 42%;    /* Medium Gray                     */

  /* ── Radius — 8px base (shadcn default); 42px pill applied selectively via .btn-ghost-outline ── */
  --radius:                   0.5rem;        /* 8px                             */

  /* ── Sidebar ── */
  --sidebar:                  0 0% 4%;
  --sidebar-foreground:       0 0% 100%;
  --sidebar-primary:          0 0% 100%;
  --sidebar-primary-foreground: 0 0% 0%;
  --sidebar-accent:           0 0% 10%;
  --sidebar-accent-foreground: 0 0% 50%;
  --sidebar-border:           222 5% 42%;
  --sidebar-ring:             0 0% 50%;
}

/* ═══════════════════════════════════════════════════════════
   .dark — identical to :root (system is dark-first)
   ═══════════════════════════════════════════════════════════ */
.dark {
  --background:               0 0% 0%;
  --foreground:               0 0% 100%;
  --card:                     0 0% 4%;
  --card-foreground:          0 0% 100%;
  --popover:                  0 0% 4%;
  --popover-foreground:       0 0% 100%;
  --primary:                  0 0% 100%;
  --primary-foreground:       0 0% 0%;
  --secondary:                0 0% 10%;
  --secondary-foreground:     0 0% 50%;
  --muted:                    0 0% 7%;
  --muted-foreground:         0 0% 50%;
  --accent:                   25 93% 42%;
  --accent-foreground:        0 0% 100%;
  --destructive:              0 72% 51%;
  --border:                   222 5% 42%;
  --input:                    222 5% 42%;
  --ring:                     0 0% 50%;
  --chart-1:                  25 93% 42%;
  --chart-2:                  86 40% 59%;
  --chart-3:                  128 58% 69%;
  --chart-4:                  162 95% 69%;
  --chart-5:                  222 5% 42%;
  --radius:                   0.5rem;
  --sidebar:                  0 0% 4%;
  --sidebar-foreground:       0 0% 100%;
  --sidebar-primary:          0 0% 100%;
  --sidebar-primary-foreground: 0 0% 0%;
  --sidebar-accent:           0 0% 10%;
  --sidebar-accent-foreground: 0 0% 50%;
  --sidebar-border:           222 5% 42%;
  --sidebar-ring:             0 0% 50%;
}

/* ═══════════════════════════════════════════════════════════
   Base layer
   ═══════════════════════════════════════════════════════════ */
@layer base {
  * {
    @apply border-border;
  }
  body {
    @apply bg-background text-foreground;
  }
  html {
    @apply font-sans;
  }

  /* Focus — аккуратный border вместо ring */
  *:focus-visible {
    outline: none !important;
    box-shadow: none !important;
  }

  input:focus-visible,
  textarea:focus-visible,
  select:focus-visible,
  button:focus-visible {
    outline: none !important;
  }
}

/* ═══════════════════════════════════════════════════════════
   Utility classes — editorial surfaces, tactile feedback
   ═══════════════════════════════════════════════════════════ */
@layer utilities {
  /* Editorial card — dark surface with 1px medium-gray border */
  .glass {
    background: hsl(0 0% 4%);
    border: 1px solid hsl(222 5% 42%);
    backdrop-filter: blur(12px);
  }
  .glass-hover {
    transition: border-color 300ms, background 300ms;
  }
  .glass-hover:hover {
    border-color: hsl(0 0% 50%);
  }

  /* Diffusion shadow — on dark, very subtle */
  .shadow-diffuse {
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.60);
  }
  .shadow-diffuse-sm {
    box-shadow: 0 2px 8px rgba(0,0,0,0.40);
  }

  /* Editorial tracking for headings — 0.15em per design system */
  .tracking-tight-heading {
    letter-spacing: 0.15em;
  }

  /* Editorial card surface */
  .card-surface {
    border-radius: var(--radius-lg);
    border: 1px solid hsl(222 5% 42%);
    background: hsl(0 0% 4%);
  }
  .card-surface-hover {
    border-radius: var(--radius-lg);
    border: 1px solid hsl(222 5% 42%);
    background: hsl(0 0% 4%);
    transition: border-color 300ms, box-shadow 300ms;
  }
  .card-surface-hover:hover {
    border-color: hsl(0 0% 50%);
    box-shadow: 0 8px 40px -12px rgba(205,90,7,0.18);
  }

  /* Tactile feedback */
  .btn-tactile:active {
    transform: scale(0.98) translateY(1px);
  }

  /* Nebula gradient background utility */
  .bg-nebula {
    background: var(--gradient-nebula);
  }

  /* Ghost button — outlined, pill-shaped */
  .btn-ghost-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ffffff;
    border-radius: 42px;
    color: #ffffff;
    background: transparent;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: background 200ms, color 200ms;
  }
  .btn-ghost-outline:hover {
    background: rgba(255,255,255,0.08);
  }
}

/* ═══════════════════════════════════════════════════════════
   Keyframe animations
   ═══════════════════════════════════════════════════════════ */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes border-beam {
  0% { offset-distance: 0%; }
  100% { offset-distance: 100%; }
}

@keyframes gradient-flow {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes marquee {
  0% { transform: translateX(0%); }
  100% { transform: translateX(-100%); }
}

@keyframes float-slow {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-14px); }
}

@keyframes float-reverse {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(12px); }
}

@layer utilities {
  .animate-shimmer {
    animation: shimmer 2.5s ease-in-out infinite;
    background-size: 200% 100%;
  }
  .animate-gradient-flow {
    animation: gradient-flow 6s ease infinite;
    background-size: 200% 200%;
  }
  .animate-fade-in-up {
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  .animate-float-slow {
    animation: float-slow 6s ease-in-out infinite;
  }
  .animate-float-reverse {
    animation: float-reverse 5s ease-in-out infinite;
  }
  /* Staggered cascade — set --index on element */
  .animate-stagger {
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--index, 0) * 80ms);
  }
}

/* ═══════════════════════════════════════════════════════════
   Print — PDF optimization via Playwright / browser print
   ═══════════════════════════════════════════════════════════ */
@media print {
  /* Force white background, no margins on body */
  html, body {
    background: white !important;
    margin: 0 !important;
    padding: 0 !important;
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }

  /* Remove all animations in print */
  *, *::before, *::after {
    animation: none !important;
    transition: none !important;
  }

  /* Prevent cards and sections from splitting across pages */
  .print-avoid-break {
    break-inside: avoid !important;
    page-break-inside: avoid !important;
  }

  /* Force full width containers in print */
  .print-full-width {
    max-width: 100% !important;
    width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
  }

  /* Hide interactive elements that make no sense in PDF */
  .print-hide {
    display: none !important;
  }

  /* Force elements visible in print (e.g. collapsed accordions) */
  .print-show {
    display: block !important;
  }
}
