          id: true,
          keyword: true,
          isMentioned: true,
          mentionContext: true,
          competitors: true,
        },
      },
    },
  });

  if (!report) return null;

  const targetBrand = extractTargetBrand(projectUrl, projectName);
  const sovList = report.shareOfVoices;
