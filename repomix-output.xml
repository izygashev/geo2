                    ? "\u0421\u0432\u0435\u0440\u043d\u0443\u0442\u044c"
                    : `\u041f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e (${lines.length} \u0441\u0442\u0440\u043e\u043a)`}
                </button>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
