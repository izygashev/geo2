          <Globe className="h-4 w-4 text-[#787774]" />
          <span className="text-sm font-semibold tracking-tight text-[#1a1a1a]">Geo Studio</span>
        </Link>

        {/* Navigation */}
        <nav className="flex-1 space-y-0.5 px-3 py-4">
